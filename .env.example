APP_ENV=development
SECRET_KEY=replace-with-a-long-random-secret

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rpa

CONTROL_CENTER_HOST=0.0.0.0
CONTROL_CENTER_PORT=8090
CONTROL_CENTER_THREADS=8
CONTROL_CENTER_CONNECTION_LIMIT=100
CONTROL_CENTER_CHANNEL_TIMEOUT=120

SERVICE_BACKEND=windows
POWERSHELL_EXECUTABLE=powershell.exe
SERVICE_ACTION_TIMEOUT_SECONDS=45

HEALTHCHECK_TIMEOUT_SECONDS=3
HEALTHCHECK_VERIFY_TLS=false

LOG_DIRECTORY=C:\RPA\logs\control-center
ALLOWED_LOG_ROOTS=C:\RPA\logs;C:\Apps
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_STREAM_POLL_SECONDS=1.0

AUTH_MANAGER_URL=http://127.0.0.1:5000
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=15

CONTROL_CENTER_VIEWER_ROLES=RPA_CONTROL_VIEWER,RPA_CONTROL_OPERATOR,RPA_CONTROL_ADMIN
CONTROL_CENTER_OPERATOR_ROLES=RPA_CONTROL_OPERATOR,RPA_CONTROL_ADMIN
CONTROL_CENTER_ADMIN_ROLES=RPA_CONTROL_ADMIN

BREAK_GLASS_ENABLED=false
BREAK_GLASS_USERNAME=control-recovery
BREAK_GLASS_PASSWORD_HASH=

SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
BEHIND_PROXY=false